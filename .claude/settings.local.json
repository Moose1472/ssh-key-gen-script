{
  "permissions": {
    "allow": [
      "Bash(python ssh_manager.py --version)",
      "Bash(py --version)",
      "Bash(where python3 *)",
      "PowerShell(py --version)",
      "PowerShell($env:PATH -split \";\" | Where-Object { $_ -match \"python|conda|node\" })",
      "PowerShell($profilePath = $PROFILE.CurrentUserAllHosts; Write-Output $profilePath; if \\(Test-Path $profilePath\\) { Get-Content $profilePath } else { Write-Output \"\\(profile does not exist yet\\)\" })",
      "PowerShell($profileDir = Split-Path $PROFILE.CurrentUserAllHosts; New-Item -ItemType Directory -Path $profileDir -Force | Out-Null; Write-Output \"Profile dir ready: $profileDir\")",
      "PowerShell(. $PROFILE.CurrentUserAllHosts; jump --version)",
      "PowerShell(New-Item -ItemType Directory -Force -Path \"C:\\\\Claude\\\\ssh-key-generator\")",
      "PowerShell(New-Item -ItemType Directory -Force -Path \"C:\\\\Claude\\\\ssh-manager\")",
      "PowerShell(Move-Item \"C:\\\\Claude\\\\new-sshkey.ps1\" \"C:\\\\Claude\\\\ssh-key-generator\\\\\")",
      "PowerShell(Move-Item \"C:\\\\Claude\\\\new-sshkey.sh\"  \"C:\\\\Claude\\\\ssh-key-generator\\\\\")",
      "PowerShell(Move-Item \"C:\\\\Claude\\\\jump.ps1\"        \"C:\\\\Claude\\\\ssh-manager\\\\\")",
      "PowerShell(Move-Item \"C:\\\\Claude\\\\ssh_manager.js\"  \"C:\\\\Claude\\\\ssh-manager\\\\\")",
      "PowerShell(Move-Item \"C:\\\\Claude\\\\ssh_manager.py\"  \"C:\\\\Claude\\\\ssh-manager\\\\\")",
      "Bash(find /mnt/c/Claude -type f)",
      "Bash(git --version)",
      "Bash(gh --version)",
      "Bash(winget --version)",
      "Bash(scoop --version)",
      "Bash(choco --version)",
      "Bash(winget install *)"
    ]
  }
}
